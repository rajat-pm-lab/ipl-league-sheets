{
  "buildCommand": "node scripts/sync-certs.js && cd 02-prototype/ill-dashboard && npm install && npm run build",
  "outputDirectory": "02-prototype/ill-dashboard/dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/cron/update-results",
      "schedule": "0 18 * 3-5 *"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
